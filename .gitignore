# --- Obsidian ユーザー個別ファイル ---
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/       # 導入プラグインは各自の環境に依存
.obsidian/community-plugins.json
.obsidian/hotkeys.json

# --- macOS ---
.DS_Store

# --- 環境変数（機密情報） ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- 実名マップは暗号化前にコミットさせない ---
90_Meta/alias_map.md
!90_Meta/alias_map.md.mdenc

# --- ヘルスレポートは各自の運用で生成 ---
90_Meta/health-reports/*.md
!90_Meta/health-reports/.gitkeep

# --- raw/ 内の一次資料PDF（著作権配慮） ---
raw/**/*.pdf
raw/**/*.PDF
!raw/**/README.md

# --- amendment-reports は各自の運用で生成 ---
90_Meta/amendment-reports/*.md
!90_Meta/amendment-reports/.gitkeep

# --- MCP サーバー: ビルド成果物・venv ---
mcp_server/.venv/
mcp_server/dist/
mcp_server/build/
mcp_server/*.egg-info/
mcp_server/src/*.egg-info/
mcp_server/uv.lock
